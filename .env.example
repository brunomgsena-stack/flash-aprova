# ============================================================
# FlashAprova — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# ------ Supabase ------
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SEU_ANON_KEY
# Encontre em: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=SEU_SERVICE_ROLE_KEY

# URL base do app (sem barra no final)
NEXT_PUBLIC_URL=https://flashaprova.app

# ------ OpenAI ------
OPENAI_API_KEY=sk-proj-...
OPENAI_VECTOR_STORE_ID=vs_...

# ------ Asaas (Pagamentos) ------
ASAAS_API_KEY=$aact_prod_...
ASAAS_WEBHOOK_TOKEN=whsec_...
# URL do link de pagamento de cada plano (copie do painel Asaas)
ASAAS_PAYMENT_LINK_URL_ACELERACAO=https://www.asaas.com/c/...
ASAAS_PAYMENT_LINK_URL_PANTEAO_ELITE=https://www.asaas.com/c/...
# Opcional: sobrescreve a base URL da API Asaas (padrão: https://api.asaas.com/v3)
# ASAAS_API_URL=https://api.asaas.com/v3

# ------ Upstash Redis (Rate Limiting) ------
UPSTASH_REDIS_REST_URL=https://SEU_REDIS.upstash.io
UPSTASH_REDIS_REST_TOKEN=SEU_TOKEN

# ------ Resend (E-mails Transacionais) ------
RESEND_API_KEY=re_...

# ------ Config Opcional ------
# IDs de usuário que bypassam o rate limit (separados por vírgula)
# Encontre em: Supabase Dashboard → Authentication → Users
RATE_LIMIT_ADMIN_IDS=uuid1,uuid2

# Dev: e-mail fallback para simular usuário logado em localhost sem sessão
DEV_FALLBACK_USER_EMAIL=seu@email.com
